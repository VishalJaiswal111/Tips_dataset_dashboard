      <column caption='colorbar' datatype='string' name='[Calculation_0881582767284224]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  [Parameters].[Parameter 1]==&apos;Day&apos; then [day]&#13;&#10;ELSEIF   [Parameters].[Parameter 1]==&apos;Sex&apos; then [sex]&#13;&#10;ELSEIF   [Parameters].[Parameter 1]==&apos;Smoker&apos; then [smoker]&#13;&#10;ELSEIF [Parameters].[Parameter 1]==&apos;Time&apos; then [time]&#13;&#10;ELSE &apos;other&apos;&#13;&#10;END' />
      </column>
      <column caption='tip percent' datatype='real' name='[Calculation_1205938472214528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(100*[tip]/[total_bill],1)' />
      </column>
      <column caption='smoker %' datatype='real' name='[Calculation_1342278099595264]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100*sum(IIF( [smoker]==&apos;Yes&apos; ,1,0))/COUNT([smoker])' />
      </column>
      <column caption='Male avg bill' datatype='real' name='[Calculation_1342278101848066]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [sex] = &quot;Male&quot; THEN [total_bill]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Female avg bill' datatype='real' name='[Calculation_1342278102405123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(&#13;&#10;IF [sex] = &quot;Female&quot; THEN [total_bill]&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='Share of Dinner' datatype='real' name='[Calculation_1342278103928836]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100*SUM(IIF([time]=&quot;Dinner&quot;,1,0)) / COUNT([time])' />
      </column>
      <column caption='Share of Lunch' datatype='real' name='[Share of Dinner (copy)_1342278107004934]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='100*SUM(IIF([time]=&quot;Lunch&quot;,1,0)) / COUNT([time])' />
      </column>
